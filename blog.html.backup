<div id="promo-banner" class="promo-banner" onclick="viewPricingPlans()" style="background: var(--card-bg); color: var(--text-primary); text-align: center; padding: 10px 20px; font-weight: 500; font-size: 0.95rem; border-bottom: 1px solid var(--border-color); position: fixed; top: 0; left: 0; right: 0; z-index: 9999; cursor: pointer; transition: background 0.2s; display: none;" onmouseover="this.style.background='var(--hover-bg)'" onmouseout="this.style.background='var(--card-bg)'">
Professional Stock Analysis starting at <strong style="color: #22c55e;">$4.99/month</strong> - Get institutional-grade tools at accessible pricing
</div>
<script>
(function() {
const userId = localStorage.getItem('userId') || 'anonymous';
const cacheKey = `userPaidStatus_${userId}`;
const cachedPaidStatus = localStorage.getItem(cacheKey);
const banner = document.getElementById('promo-banner');
if (cachedPaidStatus !== 'paid' && banner) {
banner.style.display = 'block';
if (userId === 'anonymous') {
banner.innerHTML = 'Sign up FREE to get <strong style="color: #22c55e;">15 free analyses</strong> - Professional tools at your fingertips';
}
}
})();
</script>
